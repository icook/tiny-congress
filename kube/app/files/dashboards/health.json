{
  "annotations": [],
  "cursorSync": "Off",
  "elements": {
    "replicaCount": {
      "kind": "Panel",
      "spec": {
        "id": 0,
        "title": "Replicas",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "kube_deployment_status_replicas_available{namespace=\"${namespace}\", deployment=~\"tc-.*\"}",
                    "legendFormat": "{{deployment}}",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "stat",
          "version": "",
          "spec": {
            "options": {
              "graphMode": "area",
              "colorMode": "background",
              "justifyMode": "auto",
              "textMode": "auto",
              "wideLayout": true,
              "showPercentChange": false,
              "reduceOptions": {
                "calcs": []
              },
              "percentChangeColorMode": "standard",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              },
              "overrides": []
            }
          }
        }
      }
    },
    "podRestarts24h": {
      "kind": "Panel",
      "spec": {
        "id": 0,
        "title": "Pod Restarts (24h)",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"${namespace}\"}[24h]))",
                    "legendFormat": "",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "stat",
          "version": "",
          "spec": {
            "options": {
              "graphMode": "area",
              "colorMode": "background",
              "justifyMode": "auto",
              "textMode": "auto",
              "wideLayout": true,
              "showPercentChange": false,
              "reduceOptions": {
                "calcs": []
              },
              "percentChangeColorMode": "standard",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              },
              "overrides": []
            }
          }
        }
      }
    },
    "uptime": {
      "kind": "Panel",
      "spec": {
        "id": 0,
        "title": "Uptime Since Deploy",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "min(time() - kube_pod_start_time{namespace=\"${namespace}\", pod=~\"tc-.*\"})",
                    "legendFormat": "",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "stat",
          "version": "",
          "spec": {
            "options": null,
            "fieldConfig": {
              "defaults": {
                "unit": "s"
              },
              "overrides": []
            }
          }
        }
      }
    },
    "requestRate": {
      "kind": "Panel",
      "spec": {
        "id": 0,
        "title": "Request Rate by Status",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "sum by (status_code) (rate(http_requests_total{namespace=\"${namespace}\"}[5m]))",
                    "legendFormat": "{{status_code}}",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "timeseries",
          "version": "",
          "spec": {
            "options": {
              "legend": {
                "displayMode": "table",
                "placement": "right",
                "showLegend": true,
                "calcs": []
              },
              "tooltip": {
                "mode": "single",
                "sort": "asc"
              }
            },
            "fieldConfig": {
              "defaults": {
                "unit": "reqps",
                "custom": {
                  "lineWidth": 2,
                  "fillOpacity": 10
                }
              },
              "overrides": []
            }
          }
        }
      }
    },
    "latency": {
      "kind": "Panel",
      "spec": {
        "id": 0,
        "title": "Request Latency",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"${namespace}\"}[5m])))",
                    "legendFormat": "p50",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"${namespace}\"}[5m])))",
                    "legendFormat": "p95",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "B",
                  "hidden": false
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"${namespace}\"}[5m])))",
                    "legendFormat": "p99",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "C",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "timeseries",
          "version": "",
          "spec": {
            "options": null,
            "fieldConfig": {
              "defaults": {
                "unit": "s",
                "custom": {
                  "lineWidth": 2,
                  "fillOpacity": 5
                }
              },
              "overrides": []
            }
          }
        }
      }
    },
    "errorRate": {
      "kind": "Panel",
      "spec": {
        "id": 0,
        "title": "Error Rate %",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "query": {
                    "expr": "sum(rate(http_requests_total{namespace=\"${namespace}\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"${namespace}\"}[5m])) * 100",
                    "legendFormat": "",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${prometheus_datasource}"
                    }
                  },
                  "refId": "A",
                  "hidden": false
                }
              }
            ],
            "transformations": [],
            "queryOptions": {}
          }
        },
        "vizConfig": {
          "kind": "VizConfig",
          "group": "stat",
          "version": "",
          "spec": {
            "options": {
              "graphMode": "area",
              "colorMode": "background",
              "justifyMode": "auto",
              "textMode": "auto",
              "wideLayout": true,
              "showPercentChange": false,
              "reduceOptions": {
                "calcs": []
              },
              "percentChangeColorMode": "standard",
              "orientation": "auto"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "percent",
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 1
