    "/rooms/{room_id}/polls/{poll_id}/my-votes": {
      "get": {
        "tags": [
          "Polls"
        ],
        "operationId": "my_votes",
        "parameters": [
          {
            "name": "room_id",
            "in": "path",
            "description": "Room ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
