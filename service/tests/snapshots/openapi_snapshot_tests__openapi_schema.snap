          "201": {
            "description": "Endorsement created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedEndorsementResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Not an authorized verifier"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AcceptInviteResponse": {
        "type": "object",
        "required": [
          "endorser_id",
          "accepted_at"
        ],
        "properties": {
          "accepted_at": {
            "type": "string"
          },
          "endorser_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "AccountLookupResponse": {
        "type": "object",
        "description": "Account lookup response — returns only what the UI needs to target a user.",
        "required": [
          "id",
          "username"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "AddDeviceRequest": {
        "type": "object",
        "required": [
          "pubkey",
          "name",
          "certificate"
        ],
        "properties": {
          "certificate": {
            "type": "string",
            "description": "Base64url-encoded certificate (root key's signature over device pubkey)"
          },
          "name": {
            "type": "string"
          },
          "pubkey": {
            "type": "string",
            "description": "Base64url-encoded Ed25519 public key"
          }
        }
      },
      "AddDeviceResponse": {
        "type": "object",
        "required": [
          "device_kid",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "device_kid": {
            "type": "string"
          }
        }
      },
      "AssignRoleRequest": {
        "type": "object",
        "required": [
          "account_id",
          "role"
        ],
        "properties": {
          "account_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "AssignRoleResponse": {
        "type": "object",
        "required": [
          "room_id",
          "account_id",
          "role"
        ],
        "properties": {
          "account_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string"
          },
          "room_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "AuthorizeResponse": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "BackupResponse": {
        "type": "object",
        "required": [
          "encrypted_backup",
          "root_kid"
        ],
        "properties": {
          "encrypted_backup": {
            "type": "string",
            "description": "Base64url-encoded encrypted backup envelope"
          },
          "root_kid": {
            "type": "string"
          }
        }
      },
      "BotTraceResponse": {
        "type": "object",
        "required": [
          "id",
          "task",
          "run_mode",
          "steps",
          "total_cost_usd",
          "status",
          "created_at"
        ],
        "properties": {
          "completed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "created_at": {
            "type": "string"
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "run_mode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {}
          },
          "task": {
            "type": "string"
          },
          "total_cost_usd": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "BucketResponse": {
        "type": "object",
        "required": [
          "label",
          "count"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "format": "int64"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "BudgetResponse": {
        "type": "object",
        "required": [
          "slots_total",
          "slots_used",
          "slots_available",
          "out_of_slot_count",
          "denouncements_total",
          "denouncements_used",
          "denouncements_available"
        ],
        "properties": {
          "denouncements_available": {
            "type": "integer",
            "format": "int64"
          },
          "denouncements_total": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "denouncements_used": {
            "type": "integer",
            "format": "int64"
          },
          "out_of_slot_count": {
            "type": "integer",
            "format": "int64"
          },
          "slots_available": {
            "type": "integer",
            "format": "int64"
          },
          "slots_total": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "slots_used": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "BuildInfo": {
        "type": "object",
        "description": "Build metadata exposed via GraphQL, REST, and logs.\n\nLoaded from environment variables at startup (see [`BuildInfo::from_env`]).\nThese are typically set by the CI pipeline or Dockerfile at image build time.",
        "required": [
          "version",
          "gitSha",
          "buildTime"
        ],
        "properties": {
          "buildTime": {
            "type": "string",
            "description": "Build timestamp in RFC 3339 format. Read from `BUILD_TIME` env var.\nDefaults to `\"unknown\"`."
          },
          "gitSha": {
            "type": "string",
            "description": "Git commit SHA. Read from `GIT_SHA` env var. Defaults to `\"unknown\"`."
          },
          "message": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional build message (e.g., CI run URL). Read from `BUILD_MESSAGE` env var."
          },
          "version": {
            "type": "string",
            "description": "Application version string. Read from `APP_VERSION` or `VERSION` env var.\nDefaults to `\"dev\"`."
          }
        }
      },
      "CallbackQuery": {
        "type": "object",
        "description": "OAuth callback query parameters from ID.me.",
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "error_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "state": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "CreateDimensionRequest": {
