---
source: service/tests/openapi_snapshot_tests.rs
expression: schema
---
{
  "openapi": "3.1.0",
  "info": {
    "title": "TinyCongress API",
    "description": "REST API for TinyCongress",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "REST API v1"
    }
  ],
  "paths": {
    "/build-info": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Get build information",
        "description": "Returns metadata about the running service including version, git SHA, and build time.\n\n# Errors\n\nReturns `ProblemDetails` on internal server errors.",
        "operationId": "get_build_info",
        "responses": {
          "200": {
            "description": "Build information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildInfo"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/trust/budget": {
      "get": {
        "tags": [
          "Trust"
        ],
        "operationId": "budget_handler",
        "responses": {
          "200": {
            "description": "Endorsement and denouncement budget for the authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BudgetResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/trust/denounce": {
      "post": {
        "tags": [
          "Trust"
        ],
        "operationId": "denounce_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DenounceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Denouncement queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Quota exceeded"
          }
        }
      }
    },
    "/trust/denouncements/mine": {
      "get": {
        "tags": [
          "Trust"
        ],
        "operationId": "list_my_denouncements_handler",
        "responses": {
          "200": {
            "description": "List of denouncements",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DenouncementResponse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/trust/endorse": {
      "post": {
        "tags": [
          "Trust"
        ],
        "operationId": "endorse_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EndorseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Endorsement queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Quota exceeded"
          }
        }
      }
    },
    "/trust/invites": {
      "post": {
        "tags": [
          "Trust"
        ],
        "operationId": "create_invite_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInviteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Invite created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInviteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/trust/invites/mine": {
      "get": {
        "tags": [
          "Trust"
        ],
        "operationId": "list_invites_handler",
        "responses": {
          "200": {
            "description": "List of invites created by the authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvitesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/trust/invites/{id}/accept": {
      "post": {
        "tags": [
          "Trust"
        ],
        "operationId": "accept_invite_handler",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Invite ID",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Invite accepted and endorsement queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcceptInviteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Invite not found"
          }
        }
      }
    },
    "/trust/revoke": {
      "post": {
        "tags": [
          "Trust"
        ],
        "operationId": "revoke_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RevokeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Revocation queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Quota exceeded"
          }
        }
      }
    },
    "/trust/scores/me": {
      "get": {
        "tags": [
          "Trust"
        ],
        "operationId": "scores_me_handler",
        "responses": {
          "200": {
            "description": "Trust scores for the authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScoresResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/verifiers/endorsements": {
      "post": {
        "tags": [
          "Verifiers"
        ],
        "summary": "Create an endorsement as an authorized verifier.",
        "description": "Checks that the authenticated caller has the `authorized_verifier` endorsement,\nresolves the target username to an account, and creates the endorsement.\n\n# Errors\n\nReturns an error response for unauthorized, forbidden, not-found, or internal errors.",
        "operationId": "create_endorsement_as_verifier",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEndorsementRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Endorsement created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedEndorsementResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Not an authorized verifier"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AcceptInviteResponse": {
        "type": "object",
        "required": [
          "endorser_id",
          "accepted_at"
        ],
        "properties": {
          "accepted_at": {
            "type": "string"
          },
          "endorser_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "BudgetResponse": {
        "type": "object",
        "required": [
          "slots_total",
          "slots_used",
          "slots_available",
          "out_of_slot_count",
          "denouncements_total",
          "denouncements_used",
          "denouncements_available"
        ],
        "properties": {
          "denouncements_available": {
            "type": "integer",
            "format": "int64"
          },
          "denouncements_total": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "denouncements_used": {
            "type": "integer",
            "format": "int64"
          },
          "out_of_slot_count": {
            "type": "integer",
            "format": "int64"
          },
          "slots_available": {
            "type": "integer",
            "format": "int64"
          },
          "slots_total": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "slots_used": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "BuildInfo": {
        "type": "object",
        "description": "Build metadata exposed via GraphQL, REST, and logs.\n\nLoaded from environment variables at startup (see [`BuildInfo::from_env`]).\nThese are typically set by the CI pipeline or Dockerfile at image build time.",
        "required": [
          "version",
          "gitSha",
          "buildTime"
        ],
        "properties": {
          "buildTime": {
            "type": "string",
            "description": "Build timestamp in RFC 3339 format. Read from `BUILD_TIME` env var.\nDefaults to `\"unknown\"`."
          },
          "gitSha": {
            "type": "string",
            "description": "Git commit SHA. Read from `GIT_SHA` env var. Defaults to `\"unknown\"`."
          },
          "message": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional build message (e.g., CI run URL). Read from `BUILD_MESSAGE` env var."
          },
          "version": {
            "type": "string",
            "description": "Application version string. Read from `APP_VERSION` or `VERSION` env var.\nDefaults to `\"dev\"`."
          }
        }
      },
      "CreateEndorsementRequest": {
        "type": "object",
        "required": [
          "username",
          "topic"
        ],
        "properties": {
          "evidence": {},
          "topic": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "CreateInviteRequest": {
        "type": "object",
        "required": [
          "envelope",
          "delivery_method",
          "attestation"
        ],
        "properties": {
          "attestation": {},
          "delivery_method": {
            "type": "string"
          },
          "envelope": {
            "type": "string",
            "description": "base64url-encoded invite envelope bytes"
          },
          "relationship_depth": {
            "type": [
              "string",
              "null"
            ]
          },
          "weight": {
            "type": [
              "number",
              "null"
            ],
            "format": "float"
          }
        }
      },
      "CreateInviteResponse": {
        "type": "object",
        "required": [
          "id",
          "expires_at"
        ],
        "properties": {
          "expires_at": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CreatedEndorsementResponse": {
        "type": "object",
        "required": [
          "id",
          "subject_id",
          "topic",
          "issuer_id",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "issuer_id": {
            "type": "string",
            "format": "uuid"
          },
          "subject_id": {
            "type": "string",
            "format": "uuid"
          },
          "topic": {
            "type": "string"
          }
        }
      },
      "DenounceRequest": {
        "type": "object",
        "required": [
          "target_id",
          "reason"
        ],
        "properties": {
          "reason": {
            "type": "string"
          },
          "target_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "DenouncementResponse": {
        "type": "object",
        "required": [
          "id",
          "target_id",
          "target_username",
          "reason",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "reason": {
            "type": "string"
          },
          "target_id": {
            "type": "string",
            "format": "uuid"
          },
          "target_username": {
            "type": "string"
          }
        }
      },
      "EndorseRequest": {
        "type": "object",
        "required": [
          "subject_id"
        ],
        "properties": {
          "attestation": {},
          "subject_id": {
            "type": "string",
            "format": "uuid"
          },
          "weight": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "InviteResponse": {
        "type": "object",
        "required": [
          "id",
          "delivery_method",
          "expires_at"
        ],
        "properties": {
          "accepted_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "accepted_by": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "delivery_method": {
            "type": "string"
          },
          "expires_at": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "InvitesResponse": {
        "type": "object",
        "required": [
          "invites"
        ],
        "properties": {
          "invites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InviteResponse"
            }
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "description": "RFC 7807 Problem Details error response.",
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "Human-readable explanation specific to this occurrence"
          },
          "extensions": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ProblemExtensions",
                "description": "Additional error details"
              }
            ]
          },
          "instance": {
            "type": [
              "string",
              "null"
            ],
            "description": "URI reference identifying the specific occurrence"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP status code",
            "minimum": 0
          },
          "title": {
            "type": "string",
            "description": "Short human-readable summary"
          },
          "type": {
            "type": "string",
            "description": "URI reference identifying the problem type"
          }
        }
      },
      "ProblemExtensions": {
        "type": "object",
        "description": "Extended error information mapping to GraphQL error codes.",
        "required": [
          "code"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code matching GraphQL error codes"
          },
          "field": {
            "type": [
              "string",
              "null"
            ],
            "description": "Field that caused the error (for validation errors)"
          }
        }
      },
      "RevokeRequest": {
        "type": "object",
        "required": [
          "subject_id"
        ],
        "properties": {
          "subject_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ScoreSnapshotResponse": {
        "type": "object",
        "required": [
          "computed_at"
        ],
        "properties": {
          "computed_at": {
            "type": "string"
          },
          "context_user_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "eigenvector_centrality": {
            "type": [
              "number",
              "null"
            ],
            "format": "float"
          },
          "path_diversity": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          },
          "trust_distance": {
            "type": [
              "number",
              "null"
            ],
            "format": "float"
          }
        }
      },
      "ScoresResponse": {
        "type": "object",
        "required": [
          "scores"
        ],
        "properties": {
          "scores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScoreSnapshotResponse"
            }
          }
        }
      }
    }
  }
}
