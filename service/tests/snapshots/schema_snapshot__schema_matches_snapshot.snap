-- Schema Snapshot
-- Generated by schema_snapshot test
-- Update: cargo insta review

CREATE TABLE account_backups (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    account_id UUID NOT NULL,
    kid TEXT NOT NULL,
    encrypted_backup BYTEA NOT NULL,
    salt BYTEA NOT NULL,
    version INT4 NOT NULL DEFAULT 1,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE accounts (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    username TEXT NOT NULL,
    root_pubkey TEXT NOT NULL,
    root_kid TEXT NOT NULL,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE device_keys (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    account_id UUID NOT NULL,
    device_kid TEXT NOT NULL,
    device_pubkey TEXT NOT NULL,
    device_name TEXT NOT NULL,
    certificate BYTEA NOT NULL,
    last_used_at TIMESTAMPTZ,
    revoked_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE reputation__endorsements (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    subject_id UUID NOT NULL,
    topic TEXT NOT NULL,
    endorser_id UUID,
    evidence JSONB,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    revoked_at TIMESTAMPTZ,
    weight FLOAT4 NOT NULL DEFAULT 1.0,
    attestation JSONB,
    in_slot BOOL NOT NULL DEFAULT true);

CREATE TABLE reputation__external_identities (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    account_id UUID NOT NULL,
    provider TEXT NOT NULL,
    provider_subject TEXT NOT NULL,
    linked_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE request_nonces (
    nonce_hash BYTEA NOT NULL,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE rooms__bot_traces (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    room_id UUID NOT NULL,
    poll_id UUID,
    task TEXT NOT NULL,
    run_mode TEXT NOT NULL,
    steps JSONB NOT NULL DEFAULT '[]'::jsonb,
    total_cost_usd NUMERIC NOT NULL DEFAULT 0,
    status TEXT NOT NULL DEFAULT 'running'::text,
    error TEXT,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    completed_at TIMESTAMPTZ);

CREATE TABLE rooms__lifecycle_queue (
    id INT8 NOT NULL DEFAULT nextval('rooms__lifecycle_queue_id_seq'::regclass),
    message_type TEXT NOT NULL,
    payload JSONB NOT NULL,
    visible_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    created_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE rooms__poll_dimensions (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    poll_id UUID NOT NULL,
    name TEXT NOT NULL,
    description TEXT,
    min_value FLOAT4 NOT NULL DEFAULT 0.0,
    max_value FLOAT4 NOT NULL DEFAULT 1.0,
    sort_order INT4 NOT NULL DEFAULT 0,
    min_label TEXT,
    max_label TEXT);

CREATE TABLE rooms__poll_evidence (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    dimension_id UUID NOT NULL,
    stance TEXT NOT NULL,
    claim TEXT NOT NULL,
    source TEXT,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE rooms__polls (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    room_id UUID NOT NULL,
    question TEXT NOT NULL,
    description TEXT,
    status TEXT NOT NULL DEFAULT 'draft'::text,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    activated_at TIMESTAMPTZ,
    closed_at TIMESTAMPTZ,
    closes_at TIMESTAMPTZ,
    agenda_position INT4);

CREATE TABLE rooms__research_suggestions (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    room_id UUID NOT NULL,
    account_id UUID NOT NULL,
    suggestion_text TEXT NOT NULL,
    status TEXT NOT NULL DEFAULT 'queued'::text,
    filter_reason TEXT,
    evidence_ids _UUID NOT NULL DEFAULT '{}'::uuid[],
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    processed_at TIMESTAMPTZ);

CREATE TABLE rooms__role_assignments (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    room_id UUID NOT NULL,
    account_id UUID NOT NULL,
    role TEXT NOT NULL,
    assigned_by UUID NOT NULL,
    assigned_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE rooms__rooms (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    description TEXT,
    eligibility_topic TEXT NOT NULL DEFAULT 'identity_verified'::text,
    status TEXT NOT NULL DEFAULT 'open'::text,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    closed_at TIMESTAMPTZ,
    constraint_type TEXT NOT NULL DEFAULT 'endorsed_by'::text,
    constraint_config JSONB NOT NULL DEFAULT '{}'::jsonb,
    poll_duration_secs INT4,
    engine_type TEXT NOT NULL DEFAULT 'polling'::text,
    engine_config JSONB NOT NULL DEFAULT '{}'::jsonb,
    owner_id UUID);

CREATE TABLE rooms__votes (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    poll_id UUID NOT NULL,
    dimension_id UUID NOT NULL,
    user_id UUID NOT NULL,
    value FLOAT4 NOT NULL,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE trust__action_queue (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    actor_id UUID NOT NULL,
    action_type TEXT NOT NULL,
    payload JSONB NOT NULL,
    status TEXT NOT NULL DEFAULT 'pending'::text,
    quota_date DATE NOT NULL DEFAULT CURRENT_DATE,
    error_message TEXT,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    processed_at TIMESTAMPTZ);

CREATE TABLE trust__denouncements (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    accuser_id UUID NOT NULL,
    target_id UUID NOT NULL,
    reason TEXT NOT NULL,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    resolved_at TIMESTAMPTZ);

CREATE TABLE trust__invites (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    endorser_id UUID NOT NULL,
    envelope BYTEA NOT NULL,
    delivery_method TEXT NOT NULL,
    attestation JSONB NOT NULL,
    accepted_by UUID,
    expires_at TIMESTAMPTZ NOT NULL,
    accepted_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    relationship_depth TEXT,
    weight FLOAT4 NOT NULL DEFAULT 1.0);

CREATE TABLE trust__score_snapshots (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL,
    context_user_id UUID,
    trust_distance FLOAT4,
    path_diversity INT4,
    eigenvector_centrality FLOAT4,
    computed_at TIMESTAMPTZ NOT NULL DEFAULT now());

CREATE TABLE trust__user_influence (
    user_id UUID NOT NULL,
    total_influence FLOAT4 NOT NULL DEFAULT 10.0,
    staked_influence FLOAT4 NOT NULL DEFAULT 0,
    spent_influence FLOAT4 NOT NULL DEFAULT 0,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

