# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tinycongress

# Session Token Signing
# Generate with: openssl rand -base64 32
SESSION_SIGNING_KEY=your-secret-key-here

# Optional: Previous key for zero-downtime rotation
# SESSION_SIGNING_KEY_OLD=old-secret-key-here

# Server Configuration (optional)
# PORT=8080
# HOST=0.0.0.0

# Logging (optional)
# RUST_LOG=info,tinycongress_api=debug
