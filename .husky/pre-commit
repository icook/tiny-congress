#!/usr/bin/env sh

# Lint staged frontend files
cd web && npx lint-staged
frontend_status=$?

# Lint Rust files if any .rs files are staged
cd ..
if git diff --cached --name-only | grep -q '\.rs$'; then
  echo "Running cargo fmt check..."
  cd service && cargo fmt --all -- --check
  fmt_status=$?

  if [ $fmt_status -ne 0 ]; then
    echo "Rust formatting check failed. Run 'cargo fmt' in service/ to fix."
    exit 1
  fi

  echo "Running cargo clippy..."
  cargo clippy --all-features -- -D warnings
  clippy_status=$?

  if [ $clippy_status -ne 0 ]; then
    echo "Clippy check failed. Fix the warnings above."
    exit 1
  fi
fi

# Guard: docs/plans/ should not exist — use .plan/ for ephemeral specs
# Only block additions (--diff-filter=d excludes deletions, so cleanup commits pass)
if git diff --cached --diff-filter=d --name-only | grep -q '^docs/plans/'; then
  echo "ERROR: docs/plans/ should not be committed. Use .plan/ for ephemeral specs."
  echo "Staged docs/plans/ files:"
  git diff --cached --diff-filter=d --name-only | grep '^docs/plans/'
  exit 1
fi

# Guard: openapi.json changes require regenerated rest.ts
if git diff --cached --name-only | grep -q 'web/openapi.json'; then
  if ! git diff --cached --name-only | grep -q 'web/src/api/generated/rest.ts'; then
    echo "web/openapi.json is staged but web/src/api/generated/rest.ts is not."
    echo "Run 'just codegen' and stage the generated file."
    exit 1
  fi
fi

exit $frontend_status
